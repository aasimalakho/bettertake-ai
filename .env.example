# --- Backblaze B2 (storage) ---
# Get these from your B2 account: https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_application_key
B2_BUCKET=your_bucket_name

# --- Replicate (image generation — the "Generator" agent) ---
# Free trial runs, no credit card to start: https://replicate.com
# Sign up, then Profile icon -> API tokens -> Create token
REPLICATE_API_TOKEN=your_replicate_token

# --- Groq (vision scoring — the "Critic" agent) ---
# Free tier, no credit card required: https://console.groq.com
# Sign up, then console.groq.com/keys -> Create API Key
GROQ_API_KEY=your_groq_api_key
